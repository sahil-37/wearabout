# API Configuration
API_TITLE=Fashion Recommendation API
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=False
ENVIRONMENT=development

# Model Configuration
MODEL_DEVICE=cpu
POSE_CONFIDENCE_THRESHOLD=0.5
YOLO_CONFIDENCE_THRESHOLD=0.4
NMS_IOU_THRESHOLD=0.45

# Feature Extraction
FEATURE_DIM=2048
RESNET_INPUT_SIZE=224

# Similarity Search
DEFAULT_K_NEIGHBORS=70
MAX_RECOMMENDATIONS=30
MIN_RECOMMENDATIONS=5

# File Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Model Paths
YOLO_WEIGHTS_PATH=./models/best.onnx
FEATURES_PATH=./data/features_normalized.pkl
METADATA_PATH=./data/metadata.json

# Absolute path to your product image folder (used by /product-image and build_catalog.py)
# Example: /home/user/datasets/myntra/Product
CATALOG_IMAGE_ROOT=/path/to/your/product/images

# Absolute path to your annotated dataset (used by evaluate.py)
# Example: /home/user/datasets/myntra/Annotated_Data
ANNOTATED_DATA_ROOT=/path/to/your/annotated/data

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/api.log

# CORS Origins
CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:8000", "http://localhost:8080"]
